# Copy this file to .env and add real keys locally.
# Never commit real API keys.

# Runtime persistence. Keep on for local product testing so setup,
# selected feed, events, vitals, review labels, transcripts, and Medplum
# sync status survive reloads/restarts.
HEALTHER_VISION_PERSISTENCE=1

# Cloud VLM confirmation. Local CV always runs first; when this is enabled
# and a provider key exists, event frames are sent to the configured VLM for
# monitor OCR, bed state, staff, fall, IV/oxygen, and distress confirmation.
HEALTHER_VISION_USE_CLOUD_VLM=1
HEALTHER_VISION_VLM_PROVIDER=openai
HEALTHER_VISION_VLM_TIMEOUT_SECONDS=60

# OpenAI VLM, assistant, and audio transcription.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5-mini
OPENAI_ASSISTANT_MODEL=gpt-5-mini
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_AUDIO_TRANSCRIBE_MODEL=whisper-1

# Gemini VLM alternative. Set HEALTHER_VISION_VLM_PROVIDER=gemini to use it.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# Medplum FHIR sync. Detection frames are mapped to Observation, Task,
# and DocumentReference resources when sync is enabled and credentials exist.
MEDPLUM_SYNC_ENABLED=1
MEDPLUM_BASE_URL=https://api.medplum.com
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
MEDPLUM_ACCESS_TOKEN=
MEDPLUM_ON_BEHALF_OF=
